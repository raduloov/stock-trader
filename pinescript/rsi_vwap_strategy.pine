// This Pine Script™ v6 indicator was generated by Claude
// RSI + VWAP Strategy with Risk Management
// Timeframe: 5 min
// BUY:  RSI <= 25 AND close > VWAP
// SELL: RSI >= 75 AND close < VWAP
// SL:   Last 15-min candle low (long) / high (short)
// TP:   1:2 RRR
// Risk: 0.5% of $50,000 account per trade

//@version=6
strategy("RSI + VWAP Strategy", overlay=true, initial_capital=50000, default_qty_type=strategy.cash, currency=currency.USD, commission_type=strategy.commission.percent, commission_value=0)

// === INPUTS ===
rsiLength    = input.int(14, "RSI Length")
rsiBuyLevel  = input.float(25, "RSI Buy (<=)")
rsiSellLevel = input.float(75, "RSI Sell (>=)")
riskPct      = input.float(0.5, "Risk % of Capital") / 100
rrRatio      = input.float(2.0, "Reward:Risk Ratio")

// === INDICATORS ===
rsiValue = ta.rsi(close, rsiLength)
vwapValue = ta.vwap

// === 15-MINUTE CANDLE (last 3 five-min bars) ===
high15 = ta.highest(high, 3)
low15  = ta.lowest(low, 3)

// === CONDITIONS ===
longCondition  = rsiValue <= rsiBuyLevel and close > vwapValue
shortCondition = rsiValue >= rsiSellLevel and close < vwapValue

// === POSITION SIZING ===
// Risk 0.5% of equity per trade
riskAmount = strategy.equity * riskPct

// Long: SL = last 15-min low, TP = entry + 2x stop distance
longStopDist = close - low15
longSL       = low15
longTP       = close + (longStopDist * rrRatio)
longQty      = longStopDist > 0 ? riskAmount / longStopDist : 0

// Short: SL = last 15-min high, TP = entry - 2x stop distance
shortStopDist = high15 - close
shortSL       = high15
shortTP       = close - (shortStopDist * rrRatio)
shortQty      = shortStopDist > 0 ? riskAmount / shortStopDist : 0

// === ENTRIES ===
if longCondition and strategy.position_size == 0 and longStopDist > 0
    strategy.entry("Long", strategy.long, qty=longQty)
    strategy.exit("Long Exit", "Long", stop=longSL, limit=longTP)

if shortCondition and strategy.position_size == 0 and shortStopDist > 0
    strategy.entry("Short", strategy.short, qty=shortQty)
    strategy.exit("Short Exit", "Short", stop=shortSL, limit=shortTP)

// === PLOTS ===
plot(vwapValue, "VWAP", color=color.orange, linewidth=2)
plotshape(longCondition and strategy.position_size == 0 and longStopDist > 0, "Buy Signal", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(shortCondition and strategy.position_size == 0 and shortStopDist > 0, "Sell Signal", shape.triangledown, location.abovebar, color.red, size=size.small)

// === INFO TABLE ===
var table infoTable = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(infoTable, 0, 0, "RSI", text_color=color.white)
    table.cell(infoTable, 1, 0, str.tostring(rsiValue, "#.0"), text_color=rsiValue <= rsiBuyLevel ? color.green : rsiValue >= rsiSellLevel ? color.red : color.white)
    table.cell(infoTable, 0, 1, "VWAP", text_color=color.white)
    table.cell(infoTable, 1, 1, str.tostring(vwapValue, "#.##"), text_color=close > vwapValue ? color.green : color.red)
    table.cell(infoTable, 0, 2, "15m High", text_color=color.white)
    table.cell(infoTable, 1, 2, str.tostring(high15, "#.##"), text_color=color.white)
    table.cell(infoTable, 0, 3, "15m Low", text_color=color.white)
    table.cell(infoTable, 1, 3, str.tostring(low15, "#.##"), text_color=color.white)
